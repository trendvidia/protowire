  name: "fixtures.literals.sample"
  args {
    name: "value"
    literal {
      message {
        type_url: "type.googleapis.com/fixtures.literals.Money"
        value: "\n\003USD\020\005"
      }
    }
  }
  location { file: "fixtures/literals.proto" line: 54 column: 5 }
}
entries {
  name: "fixtures.literals.allowed"
  args {
    name: "values"
    literal {
      list {
        elements { string_value: "US" }
        elements { string_value: "CA" }
        elements { string_value: "GB" }
